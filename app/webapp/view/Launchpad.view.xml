<mvc:View controllerName="entitec.pbi.embedding.controller.Launchpad" xmlns:html="http://www.w3.org/1999/xhtml" xmlns:mvc="sap.ui.core.mvc" xmlns:core="sap.ui.core" xmlns="sap.m">
  <Page id="idLaunchpad" showHeader="false">

    <MessageStrip text="{i18n>Apps}" type="Information" class="sapUiTinyMarginBegin sapUiTinyMarginEnd sapUiMediumMarginTop" />

    <FlexBox direction="Row" wrap="Wrap" justifyContent="Start" class="sapUiSmallMargin tileContainer">
      <GenericTile frameType="OneByOne" class="--sapTile_Hover_Background tileLayout" header="{i18n>REPORT}" subheader="{i18n>PowerBIEmbedded}" tooltip="{i18n>OpenReport}" id="idReport" press="press">
        <TileContent>
          <ImageContent src="sap-icon://filter-analytics" />
        </TileContent>
      </GenericTile>
    </FlexBox>


    <MessageStrip id="configMsgStrip" text="{i18n>Configuration}" type="Information" class="sapUiTinyMarginBegin sapUiTinyMarginEnd sapUiMediumMarginTop" />

    <FlexBox direction="Row" wrap="Wrap" justifyContent="Start" class="sapUiSmallMargin tileContainer">

      <GenericTile frameType="OneByOne" class="--sapTile_Hover_Background tileLayout" header="{i18n>Configuration}" subheader="{i18n>SettingsOverview}" tooltip="{i18n>ViewConfiguration}" id="idConfiguration" press="press">
        <TileContent>
          <ImageContent src="sap-icon://action-settings" />
        </TileContent>
      </GenericTile>

      <GenericTile frameType="OneByOne" class="--sapTile_Hover_Background tileLayout" header="{i18n>Administration}" subheader="{i18n>UsersAndCompanies}" tooltip="{i18n>Administration}" id="idAdministration" press="press">

        <TileContent>
          <ImageContent src="sap-icon://shield" />
        </TileContent>
      </GenericTile>



    </FlexBox>
  </Page>
</mvc:View>