<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
  <Dialog id="dynamicFilterDialog" title="Apply Security Filters" contentWidth="auto" contentHeight="auto" resizable="true" draggable="true" class="sapUiContentPadding">

    <Table items="{path: 'filters>/fields', templateShareable: false}" inset="false" fixedLayout="false" width="100%">
      <columns>
        <Column>
          <Text text="{i18n>TABLE}" />
        </Column>
        <Column>
          <Text text="{i18n>COLUMN}" />
        </Column>
        <Column>
          <Text text="{i18n>VALUE}" />
        </Column>
      </columns>

      <items>
        <ColumnListItem>
          <cells>
            <Text text="{filters>table}" />
            <Text text="{filters>column}" />

            <!-- Conditional Inputs -->
            <VBox>
              <Input visible="{=${filters>requireSingleSelection}}" placeholder="{i18n>EnterValue}" width="100%" value="{filters>value}" />

              <MultiInput visible="{=${filters>requireSingleSelection}===false}" width="100%" placeholder="{i18n>EnterValue}." showValueHelp="false" tokens="{filters>tokens}" tokenUpdate=".onTokenUpdate" submit=".onFreeTextSubmit">
                <tokens>
                  <Token text="{filters>text}" />
                </tokens>
              </MultiInput>

            </VBox>

          </cells>
        </ColumnListItem>
      </items>
    </Table>

    <beginButton>
      <Button text="{i18n>ok}" type="Emphasized" press="._onSubmitSecurityFilters" />
    </beginButton>
    <endButton>
      <Button text="{i18n>cancel}" press=".onCloseFilterDialog" />
    </endButton>
  </Dialog>
</core:FragmentDefinition>