<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
  <Dialog id="idEditCompaniesDialog" class="sapUiResponsiveMargin">
    <VBox class="sapUiSmallMargin" >
      <Label required="true" text="{i18n>Name}" labelFor="idCompanyName" />
      <Input id="idCompanyName" width="98%" value="{name}" />
      <Label required="true" text="{i18n>ContactDetails}" labelFor="idContactDetails" />
      <Input id="idContactDetails" width="98%" value="{contactDetails}" />
    </VBox>
    <buttons>
      <Button id="idAddCompany" text="{i18n>ok}" type="Emphasized" press="onSaveEditCompanyDialog" />
      <Button text="{i18n>cancel}" press="onCloseEditCompanyDialog" />
    </buttons>
  </Dialog>
</core:FragmentDefinition>
