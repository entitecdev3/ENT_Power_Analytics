<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:layout="sap.ui.layout.form">
  <VBox alignItems="Center" fitContainer="true" height="100%" class="sapUiContentPadding">

    <Table id="idTableRegisterUsers" autoPopinMode="true" updateFinished=".onUpdateFinished" mode="Delete" items="{path: '/Users', parameters: { $$updateGroupId: 'UserChanges' }, templateShareable: false }" fixedLayout="true" alternateRowColors="true" delete="onDeleteUser">

      <headerToolbar>
        <Toolbar id="lineItemsToolbarUsers">
          <ToolbarSpacer />
          <Button icon="sap-icon://refresh" text="{i18n>Refresh}" press="onRefreshUsers" />
          <Button text="{i18n>Add}" icon="sap-icon://add" press="onAddUser" />
        </Toolbar>
      </headerToolbar>

      <columns>
        <Column><Label text="{i18n>Name}" /></Column>
        <Column><Label text="{i18n>Email}" /></Column>
        <Column><Label text="{i18n>Company}" /></Column>
        <Column><Label text="{i18n>Role}" /></Column>
        <Column><Label text="{i18n>ResetPassword}" /></Column>
      </columns>

      <items>
        <ColumnListItem id="idColumnlist" type="Active" press="onUserSelect" highlight="{= ${appView>/hasChanged} ? 'Information' : 'None' }">
          <cells>
            <Text text="{username}" />
            <Text text="{email}" />
            <Text text="{parts: [{path: 'company_ID'}, {path: 'appView>/Companies'}] , formatter: '.formatter.formatCompanyDisplay'}" />
            <Text text="{parts: [{path: 'role_ID'}, {path: 'appView>/Roles'}], formatter: '.formatter.formatRoleDisplay'}" />
            <Button id="idResetUserPswd" icon="sap-icon://reset" type="Attention" text="Password" press="onResetPassword" />
          </cells>
        </ColumnListItem>
      </items>

    </Table>
  </VBox>
</core:FragmentDefinition>